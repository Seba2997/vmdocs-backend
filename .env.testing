# Base de datos local (contenedor PostgreSQL)
DATABASE_URL=postgresql://vmdocs:vmdocs@db:5432/vmdocs

# Supabase no se usa en testing — se dejan vacias a proposito
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_BUCKET=

# Almacenamiento local en disco (en vez de Supabase Storage)
STORAGE_BACKEND=local
UPLOAD_DIR=/uploads

# JWT
SECRET_KEY=testing-secret-key-vmdocs-demo-2024
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Documentos
TAMANO_MAXIMO_MB=50

# Groq AI desactivado en testing (se dejan vacias)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_CHARS=15000

# SMTP desactivado en testing (se dejan vacias)
SMTP_SERVER=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
